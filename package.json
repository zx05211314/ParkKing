{
  "name": "parkking",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run ops:assert-no-node-imports && tsc -b && vite build",
    "ingest": "tsx scripts/ingest/runAll.ts",
    "ingest:all": "tsx scripts/ingest/ingestAll.ts",
    "ingest:all:dry": "tsx scripts/ingest/ingestAll.ts --dryRun",
    "lint": "eslint .",
    "bench:evaluate": "tsx scripts/bench/benchEvaluate.ts",
    "ops:baseline": "tsx scripts/ops/generateBaselines.ts",
    "ops:baseline:force": "tsx scripts/ops/generateBaselines.ts --force",
    "ops:baseline:seed": "tsx scripts/ops/generateBaselines.ts --seed",
    "ops:publish-gate": "tsx scripts/ops/publishGate.ts --report public/data/generated/ingest_all_report.json",
    "ops:rollback": "tsx scripts/ops/rollbackPack.ts",
    "ops:cleanup": "tsx scripts/ops/cleanupBackups.ts",
    "ops:validate-configs": "tsx scripts/ops/validateConfigs.ts",
    "ops:assert-no-node-imports": "tsx scripts/ops/assertNoNodeImports.ts",
    "ops:fetch-sources": "tsx scripts/ops/fetchSources.ts",
    "ops:unpack-sources": "tsx scripts/ops/unpackSources.ts",
    "ops:sync-public-data": "tsx scripts/ops/syncPublicData.ts",
    "ops:smoke-public-data": "tsx scripts/ops/smokePublicData.ts",
    "ops:sample-qa": "tsx scripts/ops/sampleQaCandidates.ts",
    "ops:report-gate-anomalies": "tsx scripts/ops/reportGateAnomalies.ts",
    "ops:export-overrides": "tsx scripts/ops/exportOverrides.ts",
    "ops:smoke-latest": "tsx scripts/ops/smokeLoadLatest.ts",
    "ops:smoke-taipei": "tsx scripts/ops/smokeLoadLatest.ts --expected \"xinyi,daan,zhongshan\"",
    "ops:write-metrics-history": "tsx scripts/ops/writeMetricsHistory.ts",
    "ops:notify-nightly": "tsx scripts/ops/notifyNightly.ts",
    "ops:new-district": "tsx scripts/ops/newDistrict.ts",
    "ops:check-inputs": "tsx scripts/ops/checkDistrictInputs.ts",
    "ops:package-release": "tsx scripts/ops/packageRelease.ts",
    "ops:diff-packs": "tsx scripts/ops/diffPacks.ts",
    "ops:diff-latest": "tsx scripts/ops/diffPacks.ts",
    "debug:aggregate": "tsx scripts/debug/aggregateBundles.ts",
    "test": "vitest run",
    "test:update-snapshots": "cross-env UPDATE_SNAPSHOTS=1 vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@turf/turf": "^7.3.3",
    "adm-zip": "^0.5.16",
    "csv-parse": "^5.6.0",
    "maplibre-gl": "^5.17.0",
    "proj4": "^2.12.1",
    "rbush": "^4.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shapefile": "^0.6.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/rbush": "^4.0.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fast-glob": "^3.3.2",
    "globals": "^16.5.0",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^3.2.4"
  }
}
